---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  currentSlug: string;
}

const { title, description, currentSlug } = Astro.props;

const allDocs = await getCollection('docs');
const sorted = allDocs
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const navItems = sorted.map((doc) => ({
  slug: doc.slug,
  title: doc.data.title,
}));
---
<BaseLayout title={`${title} — FunnelBarn Docs`} description={description}>
  <Nav />
  <div class="max-w-6xl mx-auto px-6 py-10 flex gap-10">
    <!-- Sidebar -->
    <aside class="hidden lg:block w-56 flex-shrink-0">
      <nav class="sticky top-10">
        <p class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: #4a5568;">Documentation</p>
        <ul class="space-y-1">
          {navItems.map(item => (
            <li>
              <a
                href={`/docs/${item.slug}`}
                class={`block px-3 py-1.5 rounded text-sm transition-colors ${
                  item.slug === currentSlug
                    ? 'font-medium'
                    : 'hover:text-white'
                }`}
                style={item.slug === currentSlug
                  ? 'background-color: #1e1e35; color: #6366f1;'
                  : 'color: #8b95a1;'}
              >
                {item.title}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>

    <!-- Main content -->
    <main class="min-w-0 flex-1">
      <article class="prose-docs">
        <slot />
      </article>
    </main>
  </div>
  <Footer />
</BaseLayout>

<style>
  .prose-docs :global(h1) {
    font-size: 1.875rem;
    font-weight: 700;
    color: #e2e8f0;
    margin-bottom: 1rem;
    line-height: 1.25;
  }
  .prose-docs :global(h2) {
    font-size: 1.25rem;
    font-weight: 600;
    color: #e2e8f0;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose-docs :global(h3) {
    font-size: 1rem;
    font-weight: 600;
    color: #cbd5e0;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose-docs :global(p) {
    color: #a0aec0;
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .prose-docs :global(a) {
    color: #6366f1;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose-docs :global(a:hover) {
    color: #818cf8;
  }
  .prose-docs :global(ul), .prose-docs :global(ol) {
    color: #a0aec0;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .prose-docs :global(li) {
    margin-bottom: 0.25rem;
    line-height: 1.75;
  }
  .prose-docs :global(code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.875em;
    background-color: #1a1a2e;
    color: #a5b4fc;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    border: 1px solid #1e1e35;
  }
  .prose-docs :global(pre) {
    background-color: #0a0a14;
    border: 1px solid #1e1e35;
    border-radius: 0.5rem;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }
  .prose-docs :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.8125rem;
    color: #cbd5e0;
    line-height: 1.6;
  }
  .prose-docs :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
  }
  .prose-docs :global(th) {
    text-align: left;
    padding: 0.5rem 0.75rem;
    font-weight: 600;
    color: #e2e8f0;
    border-bottom: 1px solid #1e1e35;
  }
  .prose-docs :global(td) {
    padding: 0.5rem 0.75rem;
    color: #a0aec0;
    border-bottom: 1px solid #161625;
    vertical-align: top;
  }
  .prose-docs :global(hr) {
    border-color: #1e1e35;
    margin: 2rem 0;
  }
  .prose-docs :global(blockquote) {
    border-left: 3px solid #6366f1;
    padding-left: 1rem;
    color: #8b95a1;
    font-style: italic;
    margin-bottom: 1rem;
  }
</style>
