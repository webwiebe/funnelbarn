---
---
<section id="features" class="max-w-5xl mx-auto px-6 pb-24">
  <h2 class="text-xl font-semibold mb-8 font-mono" style="color: #e2e8f0;">
    <span style="color: #6366f1;">#</span> Features
  </h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">

    <!-- Privacy-First Sessions -->
    <div class="rounded-lg p-5" style="background-color: #161625; border: 1px solid #1e1e35;">
      <div class="mb-3" style="color: #6366f1;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
      </div>
      <h3 class="font-semibold text-sm mb-1.5" style="color: #e2e8f0;">Privacy-First Sessions</h3>
      <p class="text-sm leading-relaxed" style="color: #8b95a1;">
        No cookies. Sessions fingerprinted from IP + User-Agent, server-side only. User IDs hashed, never exposed to the client.
      </p>
    </div>

    <!-- Funnel Analysis -->
    <div class="rounded-lg p-5" style="background-color: #161625; border: 1px solid #1e1e35;">
      <div class="mb-3" style="color: #6366f1;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
        </svg>
      </div>
      <h3 class="font-semibold text-sm mb-1.5" style="color: #e2e8f0;">Funnel Analysis</h3>
      <p class="text-sm leading-relaxed" style="color: #8b95a1;">
        Multi-step conversion funnels with per-step property filters. Conversion rates and drop-off at every step. Segment by browser, device, or UTM source.
      </p>
    </div>

    <!-- A/B Test Analysis -->
    <div class="rounded-lg p-5" style="background-color: #161625; border: 1px solid #1e1e35;">
      <div class="mb-3" style="color: #6366f1;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="20" x2="18" y2="10"/>
          <line x1="12" y1="20" x2="12" y2="4"/>
          <line x1="6" y1="20" x2="6" y2="14"/>
          <line x1="2" y1="20" x2="22" y2="20"/>
        </svg>
      </div>
      <h3 class="font-semibold text-sm mb-1.5" style="color: #e2e8f0;">A/B Test Analysis</h3>
      <p class="text-sm leading-relaxed" style="color: #8b95a1;">
        Define control and variant cohorts via event property filters. Track a conversion event and see statistical breakdown of conversion rates and sample sizes.
      </p>
    </div>

    <!-- UTM Attribution -->
    <div class="rounded-lg p-5" style="background-color: #161625; border: 1px solid #1e1e35;">
      <div class="mb-3" style="color: #6366f1;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="18" cy="5" r="3"/>
          <circle cx="6" cy="12" r="3"/>
          <circle cx="18" cy="19" r="3"/>
          <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
          <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
        </svg>
      </div>
      <h3 class="font-semibold text-sm mb-1.5" style="color: #e2e8f0;">UTM Attribution</h3>
      <p class="text-sm leading-relaxed" style="color: #8b95a1;">
        Automatic UTM extraction from URLs or explicit params. Dashboard shows top sources, mediums, campaigns, terms, and content.
      </p>
    </div>

    <!-- Single Binary -->
    <div class="rounded-lg p-5" style="background-color: #161625; border: 1px solid #1e1e35;">
      <div class="mb-3" style="color: #6366f1;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
          <line x1="8" y1="21" x2="16" y2="21"/>
          <line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
      </div>
      <h3 class="font-semibold text-sm mb-1.5" style="color: #e2e8f0;">Single Binary</h3>
      <p class="text-sm leading-relaxed" style="color: #8b95a1;">
        One Go binary, SQLite on disk, no external dependencies to run. Events are spooled to disk for non-blocking ingest and processed asynchronously.
      </p>
    </div>

    <!-- SDKs Included -->
    <div class="rounded-lg p-5" style="background-color: #161625; border: 1px solid #1e1e35;">
      <div class="mb-3" style="color: #6366f1;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="16 18 22 12 16 6"/>
          <polyline points="8 6 2 12 8 18"/>
        </svg>
      </div>
      <h3 class="font-semibold text-sm mb-1.5" style="color: #e2e8f0;">SDKs Included</h3>
      <p class="text-sm leading-relaxed" style="color: #8b95a1;">
        JavaScript (browser + Node.js) and Python SDKs. Auto page view detection, custom events, user identify, and async background flush.
      </p>
    </div>

  </div>
</section>
