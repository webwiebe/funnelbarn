---
---
<!-- Hero -->
<section class="max-w-5xl mx-auto px-6 pt-24 pb-20">
  <div class="max-w-2xl">
    <div class="inline-flex items-center gap-2 text-xs font-mono px-3 py-1 rounded-full mb-8" style="background-color: #14143a; color: #818cf8; border: 1px solid #1e1e35;">
      v0.1 — open source · MIT license
    </div>
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight leading-tight mb-5" style="color: #e2e8f0;">
      Web analytics that lives on<br class="hidden sm:block" /> your infrastructure
    </h1>
    <p class="text-lg mb-8" style="color: #8b95a1; line-height: 1.7;">
      Privacy-first, no cookies required. Track events, analyze funnels, and run A/B tests — all on your own server. Your data never leaves your hands.
    </p>
    <div class="flex flex-wrap gap-3 mb-8">
      <a href="#install"
         class="inline-flex items-center px-5 py-2.5 rounded-md text-sm font-medium transition-colors"
         style="background-color: #6366f1; color: #ffffff;">
        Install in 30 seconds
      </a>
      <a href="https://github.com/webwiebe/funnelbarn"
         target="_blank" rel="noopener"
         class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md text-sm font-medium transition-colors"
         style="background-color: #161625; color: #e2e8f0; border: 1px solid #1e1e35;">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        View on GitHub
      </a>
    </div>
    <p class="text-xs font-mono" style="color: #4a5568;">
      Open source &nbsp;·&nbsp; MIT license &nbsp;·&nbsp; SQLite &nbsp;·&nbsp; Single binary &nbsp;·&nbsp; No cookies
    </p>
  </div>
</section>

<!-- Problem callout -->
<section class="max-w-5xl mx-auto px-6 pb-20">
  <div class="rounded-lg p-6 sm:p-8" style="background-color: #161625; border: 1px solid #1e1e35; border-left: 3px solid #6366f1;">
    <p class="text-base leading-relaxed" style="color: #cbd5e0;">
      Analytics SaaS sends your visitors' data to third parties, sets cookies that require consent banners, and charges per pageview.
      FunnelBarn runs on your own server, stores everything locally in SQLite, and uses anonymous session fingerprinting — no cookies, no consent prompts needed.
    </p>
  </div>
</section>
