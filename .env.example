# FunnelBarn configuration
# Copy to /etc/funnelbarn/funnelbarn.conf or ~/.config/funnelbarn/funnelbarn.conf
# Environment variables always override file values.

# ── Server ────────────────────────────────────────────────────────────────────

# Address to listen on (default: :8080)
FUNNELBARN_ADDR=:8080

# Public-facing URL used in setup pages and SDK links
FUNNELBARN_PUBLIC_URL=https://example.com

# ── Authentication ────────────────────────────────────────────────────────────

# HMAC secret for session tokens — generate with: openssl rand -hex 32
# Without this, sessions will not survive restarts.
FUNNELBARN_SESSION_SECRET=

# Admin user credentials (choose one: plaintext OR pre-hashed bcrypt)
FUNNELBARN_ADMIN_USERNAME=admin
FUNNELBARN_ADMIN_PASSWORD=changeme
# FUNNELBARN_ADMIN_PASSWORD_BCRYPT=$2b$12$...

# Session lifetime in seconds (default: 43200 = 12 hours)
# FUNNELBARN_SESSION_TTL_SECONDS=43200

# ── Ingest API key ────────────────────────────────────────────────────────────

# Static ingest API key accepted server-wide (use DB-managed keys for per-project)
# FUNNELBARN_API_KEY=your-plaintext-key

# SHA-256 hex of the API key (more secure — plaintext never stored)
# FUNNELBARN_API_KEY_SHA256=

# ── CORS ──────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins (* to allow all)
# FUNNELBARN_ALLOWED_ORIGINS=https://app.example.com,https://example.com

# ── Storage ───────────────────────────────────────────────────────────────────

# SQLite database path (default: .data/funnelbarn.db)
# FUNNELBARN_DB_PATH=.data/funnelbarn.db

# Spool directory for ingest write-ahead log (default: .data/spool)
# FUNNELBARN_SPOOL_DIR=.data/spool

# Maximum spool size in bytes before rotation (default: unlimited)
# FUNNELBARN_MAX_SPOOL_BYTES=268435456

# Maximum ingest request body size in bytes (default: 1048576 = 1 MiB)
# FUNNELBARN_MAX_BODY_BYTES=1048576

# ── Self-reporting via BugBarn (optional but recommended) ────────────────────
#
# FunnelBarn uses BugBarn (https://bugbarn.wiebe.xyz) to capture its own
# errors and structured logs. Set these to enable:
#   - Warn/Error log forwarding with structured attributes
#   - Panic capture with automatic stack fingerprinting
#   - Deployment release markers (posted by CI — see deploy workflow)
#
# Get your project key from: https://bugbarn.wiebe.xyz/api/v1/setup/funnelbarn
FUNNELBARN_SELF_ENDPOINT=https://bugbarn.wiebe.xyz
# FUNNELBARN_SELF_API_KEY=<set via SOPS secret or FUNNELBARN_BUGBARN_API_KEY in CI>
FUNNELBARN_ENVIRONMENT=production
